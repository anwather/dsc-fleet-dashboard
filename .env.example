# =============================================================================
# dsc-fleet-dashboard — environment variables
# Copy this file to .env and fill in values before `docker compose up`.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Postgres)
# -----------------------------------------------------------------------------
# When running via docker-compose the bundled postgres service is used and the
# default value below works as-is. Override only if you point at an external DB.
DATABASE_URL=postgresql://dscfleet:dscfleet@postgres:5432/dscfleet?schema=public

# Used by the bundled postgres container (must match DATABASE_URL above).
POSTGRES_USER=dscfleet
POSTGRES_PASSWORD=dscfleet
POSTGRES_DB=dscfleet

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_PORT=3000
LOG_LEVEL=info
NODE_ENV=production

# -----------------------------------------------------------------------------
# Azure credentials (optional but required for VM provisioning / Run-Command)
# DefaultAzureCredential probes env SP first, then falls back to a mounted
# `~/.azure` (AzureCliCredential) for dev. Leave blank to skip Azure features
# (the API will still boot; provisioning endpoints will return clear errors).
# -----------------------------------------------------------------------------
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# Agent / scheduler tuning
# -----------------------------------------------------------------------------
# Default poll interval for agents (seconds) — overridable per-deployment via
# the `settings` table. Agent uses this to time its loop.
AGENT_POLL_DEFAULT_SECONDS=60

# Multiplier of AGENT_POLL_DEFAULT_SECONDS after which a server with no
# heartbeat is marked offline. e.g. 60s × 3 = 180s.
OFFLINE_MULTIPLIER=3

# Default per-assignment interval in minutes when one is not specified.
DEFAULT_ASSIGNMENT_INTERVAL_MINUTES=15

# Run-Command default timeout in minutes.
AZURE_RUNCOMMAND_TIMEOUT_MINUTES=30

# Public base URL of the dashboard, reachable from the agent VMs (no trailing slash).
# Required when fronted by cloudflared / ingress / reverse proxy. If unset, the API
# falls back to the request's Host header — which on a kubectl port-forward is
# https://127.0.0.1 and useless to a remote agent.
# PUBLIC_BASE_URL=https://dsc.example.com

# How long a removal request waits for agent ack before being expirable
# from the UI (minutes).
REMOVAL_ACK_TIMEOUT_MINUTES=60

# -----------------------------------------------------------------------------
# DSC v3 schema
# -----------------------------------------------------------------------------
# URL of the bundled DSC v3 config document schema (parser fetches once
# and caches in-memory).
DSC_CONFIG_SCHEMA_URL=https://aka.ms/dsc/schemas/v3/bundled/config/document.json
