{
  "name": "dsc-fleet-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "DSC v3 Fleet Management Dashboard — self-hostable backend + UI for managing Windows Server DSC v3 deployments.",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
